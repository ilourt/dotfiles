// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // UI settings
  "icon_theme": "Material Icon Theme",
  // AI Assistant settings
  "agent": {
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "contents": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
          "web_search": true
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "code-context": {
            "tools": {
              "search_code": false,
              "index_codebase": false,
              "get_indexing_status": false,
              "clear_index": false
            }
          }
        }
      }
    },
    "always_allow_tool_actions": true,
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gemini-2.5-pro"
    }
  },
  "features": {
    "edit_prediction_provider": "copilot"
  },
  // Editor settings
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never"
  },
  "ui_font_size": 14,
  "buffer_font_size": 12,
  "soft_wrap": "editor_width",
  "vertical_scroll_margin": 20,
  "relative_line_numbers": true,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Mocha"
  },
  // Language settings
  "languages": {
    "JavaScript": {
      "language_servers": [
        "typescript-language-server",
        "biome"
      ]
    },
    "TypeScript": {
      "language_servers": [
        "biome",
        "typescript-language-server"
      ]
    },
    "CSS": {
      "language_servers": [
        "biome"
      ]
    },
    // "JavaScriptReact": {
    //   "language_servers": [
    //     "biome",
    //     "typescript-language-server",
    //     "tailwindcss-language-server"
    //   ]
    // },
    // "TypeScriptReact": {
    //   "language_servers": [
    //     "biome",
    //     "typescript-language-server",
    //     "tailwindcss-language-server"
    //   ]
    // },
    "Vue.js": {
      "language_servers": [
        "vue-language-server",
        "typescript-language-server",
        "biome",
        "tailwindcss-language-server"
      ],
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "Astro": {
      "language_servers": [
        "astro-language-server",
        "biome",
        "tailwindcss-language-server"
      ],
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "Go": {
      "language_servers": [
        "gopls"
      ]
    },
    "Elixir": {
      "language_servers": [
        "!lexical",
        "expert"
      ]
    },
    "HEEX": {
      "language_servers": [
        "!lexical",
        "expert"
      ]
    }
  },
  "lsp": {
    "expert": {
      "binary": {
        "arguments": [
          "--stdio"
        ]
      }
    }
  },
  // // "language_servers": ["!eslint"],
  "format_on_save": "on",
  "formatter": "language_server",
  "context_servers": {
    "code-context": {
      "source": "custom",
      "command": "npx",
      "args": [
        "@zilliz/claude-context-mcp@latest"
      ],
      "env": {
        "EMBEDDING_PROVIDER": "OpenAI",
        "EMBEDDING_MODEL": "text-embedding-nomic-embed-text-v2-moe",
        "OPENAI_API_KEY": "local",
        "OPENAI_BASE_URL": "http://127.0.0.1:1234/v1/",
        "MILVUS_ADDRESS": "127.0.0.1:19530",
        "MILVUS_TOKEN": "local"
      }
    }
  }
}
